<?xml version="1.0" encoding="UTF-8"?>
<robot name="mobile_manipulator">
    <!-- Groups -->
    <group name="robot_arm">
        <chain base_link="ur5e_base_link" tip_link="ur5e_tool0" />
    </group>
    <group name="hand">
        <link name="ur5e_tool0" />
    </group>

    <!-- Group States (Named Poses) -->
    <group_state name="home" group="robot_arm">
        <joint name="ur5e_shoulder_pan_joint" value="0.0" />
        <joint name="ur5e_shoulder_lift_joint" value="-1.5708" />
        <joint name="ur5e_elbow_joint" value="1.5708" />
        <joint name="ur5e_wrist_1_joint" value="-1.5708" />
        <joint name="ur5e_wrist_2_joint" value="-1.5708" />
        <joint name="ur5e_wrist_3_joint" value="0.0" />
    </group_state>
    <group_state name="stowed" group="robot_arm">
        <joint name="ur5e_shoulder_pan_joint" value="0.0" />
        <joint name="ur5e_shoulder_lift_joint" value="-3.0" />
        <joint name="ur5e_elbow_joint" value="3.0" />
        <joint name="ur5e_wrist_1_joint" value="-1.5708" />
        <joint name="ur5e_wrist_2_joint" value="-1.5708" />
        <joint name="ur5e_wrist_3_joint" value="0.0" />
    </group_state>

    <!-- End Effector -->
    <end_effector name="hand" parent_link="ur5e_tool0" group="hand" parent_group="robot_arm" />

    <!-- Disable Collisions -->
    <!-- Arm links -->
    <disable_collisions link1="ur5e_base_link_inertia" link2="ur5e_shoulder_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_base_link_inertia" link2="ur5e_upper_arm_link" reason="Never" />
    <disable_collisions link1="ur5e_base_link" link2="ur5e_shoulder_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_shoulder_link" link2="ur5e_upper_arm_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_upper_arm_link" link2="ur5e_forearm_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_forearm_link" link2="ur5e_wrist_1_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_wrist_1_link" link2="ur5e_wrist_2_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_wrist_2_link" link2="ur5e_wrist_3_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_wrist_3_link" link2="ur5e_flange" reason="Adjacent" />
    <disable_collisions link1="ur5e_flange" link2="ur5e_tool0" reason="Adjacent" />
    <disable_collisions link1="ur5e_wrist_3_link" link2="ur5e_tool0" reason="Adjacent" />

    <!-- Arm to base mount and mobile base links -->
    <disable_collisions link1="ur5e_base_link" link2="ur5e_mount_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_base_link_inertia" link2="ur5e_mount_link" reason="Adjacent" />
    <disable_collisions link1="ur5e_base_link" link2="surface" reason="Adjacent" />
    <disable_collisions link1="ur5e_base_link_inertia" link2="surface" reason="Adjacent" />
    <disable_collisions link1="ur5e_mount_link" link2="surface" reason="Adjacent" />
    <disable_collisions link1="safety_collision_volume" link2="surface" reason="Adjacent" />
    <disable_collisions link1="safety_collision_volume" link2="ur5e_mount_link" reason="Never" />
    <disable_collisions link1="safety_collision_volume" link2="ur5e_base_link" reason="Never" />
    <disable_collisions link1="safety_collision_volume" link2="ur5e_base_link_inertia" reason="Never" />
    <disable_collisions link1="safety_collision_volume" link2="ur5e_shoulder_link" reason="Never" />
    <disable_collisions link1="base_link" link2="surface" reason="Adjacent" />
    <disable_collisions link1="base_link" link2="safety_collision_volume" reason="Never" />
    <disable_collisions link1="base_link" link2="ur5e_mount_link" reason="Never" />
    <disable_collisions link1="base_link" link2="ur5e_base_link" reason="Never" />
    <disable_collisions link1="base_link" link2="ur5e_base_link_inertia" reason="Never" />
</robot>
