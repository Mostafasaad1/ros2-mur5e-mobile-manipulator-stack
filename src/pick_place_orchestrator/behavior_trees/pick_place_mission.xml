<root BTCPP_format="4">
  <BehaviorTree ID="PickPlaceMission">
    <Fallback name="root_fallback">
      <!-- Main Mission Sequence -->
      <Sequence name="main_sequence">
        
        <!-- Step 1: Target Acquisition Pick -->
        <TargetAcquisition pose="{pick_pose}"
                           phase="PICK_PHASE"
                           step="TARGET_ACQUISITION_PICK"
                           step_index="1" />
                           
        <!-- Step 2: Optimize Pick Pose -->
        <OptimizePose pose="{pick_pose}"
                      phase="PICK_PHASE"
                      step="OPTIMIZE_PICK_POSE"
                      step_index="2"
                      optimized_pose="{optimized_pick_base_pose}" />
                      
        <!-- Step 3: Navigate to Pick -->
        <NavigateToPose pose="{optimized_pick_base_pose}"
                        phase="PICK_PHASE"
                        step="NAVIGATE_TO_PICK"
                        step_index="3" />
                        
        <!-- Step 4: Execute Pick (Open, Move, Close) -->
        <GripperControl command="open"
                        phase="PICK_PHASE"
                        step="EXECUTE_PICK"
                        step_index="4" />
                        
        <MoveArm target_pose="{pick_pose}"
                 phase="PICK_PHASE"
                 step="EXECUTE_PICK"
                 step_index="4" />
                 
        <GripperControl command="close"
                        phase="PICK_PHASE"
                        step="EXECUTE_PICK"
                        step_index="4" />
                        
        <!-- Step 5: Attach Payload -->
        <AttachPayload object_id="target_payload"
                       attached_link="ur5e_tool0"
                       phase="PICK_PHASE"
                       step="ATTACH_PAYLOAD"
                       step_index="5" />
                       
        <!-- Step 6: Stow Arm Pick -->
        <MoveArm named_pose="stowed"
                 phase="PICK_PHASE"
                 step="STOW_ARM_PICK"
                 step_index="6" />
                 
        <!-- Place Phase (Guarded for isolation) -->
        <Fallback name="place_phase_guard">
          <!-- If CheckPoseCondition fails (pose is empty), this sequence succeeds, completing the Fallback early with SUCCESS -->
          <Sequence name="skip_place_check">
            <Inverter>
              <CheckPoseCondition pose="{place_pose}" />
            </Inverter>
            <AlwaysSuccess />
          </Sequence>

          <!-- Main Place Execution (runs only if CheckPoseCondition was SUCCESS) -->
          <Sequence name="place_execution">
            <!-- Step 7: Target Acquisition Place -->
            <TargetAcquisition pose="{place_pose}"
                               phase="PLACE_PHASE"
                               step="TARGET_ACQUISITION_PLACE"
                               step_index="7" />
                               
            <!-- Step 8: Optimize Place Pose -->
            <OptimizePose pose="{place_pose}"
                           phase="PLACE_PHASE"
                           step="OPTIMIZE_PLACE_POSE"
                           step_index="8"
                           optimized_pose="{optimized_place_base_pose}" />
                           
            <!-- Step 9: Navigate to Place -->
            <NavigateToPose pose="{optimized_place_base_pose}"
                            phase="PLACE_PHASE"
                            step="NAVIGATE_TO_PLACE"
                            step_index="9" />
                            
            <!-- Step 10: Execute Place (Move, Open) -->
            <MoveArm target_pose="{place_pose}"
                     phase="PLACE_PHASE"
                     step="EXECUTE_PLACE"
                     step_index="10" />
                     
            <GripperControl command="open"
                            phase="PLACE_PHASE"
                            step="EXECUTE_PLACE"
                            step_index="10" />
                            
            <!-- Step 11: Detach Payload -->
            <DetachPayload object_id="target_payload"
                           attached_link="ur5e_tool0"
                           phase="PLACE_PHASE"
                           step="DETACH_PAYLOAD"
                           step_index="11" />
                           
            <!-- Step 12: Stow Arm Place -->
            <MoveArm named_pose="stowed"
                     phase="PLACE_PHASE"
                     step="STOW_ARM_PLACE"
                     step_index="12" />
          </Sequence>
        </Fallback>
      </Sequence>
      
      <!-- Recovery Sequence (executed if any step in main_sequence fails) -->
      <Sequence name="recovery_sequence">
        <!-- Detach payload if held -->
        <DetachPayload object_id="target_payload"
                       attached_link="ur5e_tool0"
                       phase="FAILURE"
                       step="DETACH_PAYLOAD"
                       step_index="11" />
                       
        <!-- Stow arm to safe travel pose -->
        <MoveArm named_pose="stowed"
                 phase="FAILURE"
                 step="STOW_ARM"
                 step_index="12" />
                 
        <!-- Return failure to abort the mission action server -->
        <AlwaysFailure />
      </Sequence>
    </Fallback>
  </BehaviorTree>
</root>
